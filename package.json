    "restart": "pm2 restart davex-ultra && pm2 logs davex-ultra",
    "logs": "pm2 logs davex-ultra --lines 100",
    "status": "pm2 status",
    "delete": "pm2 delete davex-ultra",
    "setup": "node setup.js",
    "stash": "git stash && git stash drop"
